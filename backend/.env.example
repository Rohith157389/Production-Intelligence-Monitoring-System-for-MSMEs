PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pmrs
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Default thresholds (can be overridden per machine)
CURRENT_OVERLOAD_THRESHOLD=15
TEMPERATURE_OVERLOAD_THRESHOLD=75
RPM_DROP_PERCENT=20
VOLTAGE_MIN_THRESHOLD=200
STOPPAGE_DURATION_MINUTES=5
HIGH_TEMPERATURE_THRESHOLD=70
LOW_EFFICIENCY_THRESHOLD=60
